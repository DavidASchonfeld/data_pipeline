# Template for the GenAI credentials secret.
#
# How to use:
#   1. Copy this file to genai-secrets.yaml (same folder — it's gitignored so it stays local).
#   2. Base64-encode each value:  echo -n "your-value-here" | base64
#   3. Paste the encoded output into the value fields below.
#   4. Run ./scripts/deploy.sh with GENAI_ENABLED=true — the deploy script applies this file to the cluster.
#
# The secret is applied to the airflow-my-namespace namespace so the scheduler pod can read it.

apiVersion: v1
kind: Secret
metadata:
  name: genai-credentials
  namespace: airflow-my-namespace
type: Opaque
data:
  # LLM_API_KEY: your API key for the LLM provider (e.g. Anthropic — get it from console.anthropic.com)
  LLM_API_KEY: <BASE64_ENCODED_API_KEY>
  # LLM_PROVIDER: which AI service to use — "anthropic" is the default
  LLM_PROVIDER: <BASE64_ENCODED_PROVIDER>   # e.g. echo -n "anthropic" | base64
  # LLM_MODEL: the specific AI model to use — "claude-sonnet-4-5" is a good starting point
  LLM_MODEL: <BASE64_ENCODED_MODEL>         # e.g. echo -n "claude-sonnet-4-5" | base64
