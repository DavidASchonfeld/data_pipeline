# Deploy configuration — copy this file to .env.deploy and fill in your values.
# .env.deploy is gitignored; this example file IS committed so new developers know what's needed.

# ── AWS / ECR ─────────────────────────────────────────────────────────────────
ECR_REGISTRY="<AWS_ACCOUNT_ID>.dkr.ecr.<AWS_REGION>.amazonaws.com"
AWS_REGION="us-east-1"

# ── Snowflake bootstrap (only needed for --snowflake-setup) ───────────────────
# Admin credentials — used once to create the pipeline's warehouse, DB, schemas, role, and service user.
# Must have SYSADMIN (or equivalent) privileges on your Snowflake account.
# These are NOT the PIPELINE_USER service-account credentials used by the pipeline at runtime.
SNOWFLAKE_ACCOUNT="<ACCOUNT_IDENTIFIER>"       # e.g. abc12345.us-east-1
SNOWFLAKE_ADMIN_USER="<YOUR_SNOWFLAKE_LOGIN>"  # your personal Snowflake username
SNOWFLAKE_ADMIN_PASSWORD="<ADMIN_PASSWORD>"    # your personal Snowflake password

# ── EC2 instance credentials (needed for --provision auto-bootstrap) ──────────
# These are used to set up MariaDB and the db-credentials K8s secret when
# --provision detects a fresh spot instance that has never been bootstrapped.
# DB_PASSWORD: password for the MariaDB 'airflow_user' account.
DB_PASSWORD="replace-with-strong-password"
# SEC_EDGAR_EMAIL: email + name sent in SEC EDGAR API request headers (required by SEC fair-use policy).
SEC_EDGAR_EMAIL="your-name@example.com Your Name"
# SLACK_WEBHOOK_URL: Slack incoming webhook for alerting. Leave blank for log-only mode.
SLACK_WEBHOOK_URL=""

# ── Flask dashboard security ──────────────────────────────────────────────────
# FLASK_SECRET_KEY: used by Flask to sign sessions/cookies — must be cryptographically random.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY="replace-with-64-char-random-hex"
# VALIDATION_USER / VALIDATION_PASS: HTTP Basic Auth credentials for the /validation endpoint.
VALIDATION_USER="admin"
VALIDATION_PASS="replace-with-strong-password"
