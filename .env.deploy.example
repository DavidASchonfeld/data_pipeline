# Deploy configuration — copy this file to .env.deploy and fill in your values.
# .env.deploy is gitignored; this example file IS committed so new developers know what's needed.

# ── AWS / ECR ─────────────────────────────────────────────────────────────────
ECR_REGISTRY="<AWS_ACCOUNT_ID>.dkr.ecr.<AWS_REGION>.amazonaws.com"
AWS_REGION="us-east-1"

# ── Snowflake bootstrap (only needed for --snowflake-setup) ───────────────────
# Admin connection — used to create/verify the warehouse, DB, schemas, role, service user, and (when
# GENAI_ENABLED=true) the GenAI tables. Needs ACCOUNTADMIN. NOT the PIPELINE_USER runtime credentials.
SNOWFLAKE_ACCOUNT="<ACCOUNT_IDENTIFIER>"       # e.g. abc12345.us-east-1
SNOWFLAKE_ADMIN_USER="<ADMIN_OR_DEPLOY_USER>"  # the ACCOUNTADMIN user the bootstrap connects as
#
# Auth — pick ONE (key-pair strongly recommended):
#   RECOMMENDED — RSA key-pair. Bypasses MFA, so the deploy runs headlessly. Snowflake now enforces MFA on
#   password logins, so a personal admin + password FAILS here (error 250001/251012). Create a dedicated,
#   password-less DEPLOY_USER and its key in one step:  scripts/deploy/setup_deploy_user.sh
SNOWFLAKE_ADMIN_PRIVATE_KEY_PATH=""            # e.g. /Users/you/.snowflake/deploy_user_rsa_key.p8
#   LEGACY — password auth. Only works if the admin user has NO MFA. Leave blank if using key-pair above.
SNOWFLAKE_ADMIN_PASSWORD=""                    # personal admin password (blocked by MFA — prefer key-pair)

# ── EC2 instance credentials (needed for --provision auto-bootstrap) ──────────
# These are used to set up MariaDB and the db-credentials K8s secret when
# --provision detects a fresh spot instance that has never been bootstrapped.
# DB_PASSWORD: password for the MariaDB 'airflow_user' account.
DB_PASSWORD="replace-with-strong-password"
# SEC_EDGAR_EMAIL: email + name sent in SEC EDGAR API request headers (required by SEC fair-use policy).
SEC_EDGAR_EMAIL="your-name@example.com Your Name"
# SLACK_WEBHOOK_URL: Slack incoming webhook for alerting. Leave blank for log-only mode.
SLACK_WEBHOOK_URL=""

# ── GenAI layer (optional AI features) ───────────────────────────────────────
# Set GENAI_ENABLED=true to activate AI-powered extraction, summaries, and chat.
# When false (the default), none of the AI code runs and no API keys are required.
GENAI_ENABLED="false"
# Which AI text-generation service to use. "anthropic" is the default.
# To switch to another service, change this and create the matching provider file in genai/llm/.
LLM_PROVIDER="anthropic"
# The specific AI model to request — "claude-sonnet-4-5" balances cost and quality.
LLM_MODEL="claude-sonnet-4-5"
# Your secret API key for the provider. Get it from the provider's console (e.g. console.anthropic.com).
# Leave blank when GENAI_ENABLED=false — it is not needed.
LLM_API_KEY=""
# Reliability tunables (optional — safe defaults shown). Override only if needed.
# How long to wait on one LLM request before failing (the SDK default is ~10 minutes).
# LLM_TIMEOUT_SECONDS="60"
# How many times the SDK retries a transient 429/5xx/connection error (backoff is handled internally).
# LLM_MAX_RETRIES="3"
# Path on your Mac to the RSA private key file the Anthropic service account uses (if applicable).
# Leave blank if using API key auth only.
# SNOWFLAKE_PRIVATE_KEY_PATH="/Users/you/.ssh/pipeline_user_rsa.p8"

# ── Flask dashboard security ──────────────────────────────────────────────────
# FLASK_SECRET_KEY: used by Flask to sign sessions/cookies — must be cryptographically random.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY="replace-with-64-char-random-hex"
# VALIDATION_USER / VALIDATION_PASS: HTTP Basic Auth credentials for the /validation endpoint.
VALIDATION_USER="admin"
VALIDATION_PASS="replace-with-strong-password"
